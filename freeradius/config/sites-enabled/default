server default {
    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    authorize {
        filter_username
        preprocess
        sql
        rest
        pap
    }

    authenticate {
        Auth-Type PAP {
            pap
        }
        Auth-Type REST {
            rest
        }
    }

    preacct {
        preprocess
        acct_unique
    }

    accounting {
        sql
        rest
    }

    post-auth {
        sql
        Post-Auth-Type REJECT {
            sql
        }
    }
}
